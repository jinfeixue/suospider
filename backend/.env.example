# Spider Manager V1.0 Environment Configuration
# Copy this file to .env and modify as needed

# Application
APP_NAME=Spider Manager V1.0
DEBUG=true

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=spider

# JWT Authentication
SECRET_KEY=spider-manager-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Task Manager
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT=1800

# Scheduler
SCHEDULER_ENABLED=true
